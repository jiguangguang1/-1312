# YAOLO Weverse Con 2026 环境配置
# 复制为 .env 并修改

# Flask
FLASK_ENV=production

# ⚠️ 管理员密码（必须修改！首次启动生效）
ADMIN_PASSWORD=change_me_in_production

# ⚠️ JWT & Session 密钥（必须设置固定值，否则重启后所有 token 失效）
SECRET_KEY=generate_a_random_string_here_64chars
JWT_SECRET_KEY=generate_another_random_string_here_64chars

# ⚠️ 敏感字段加密密钥（用于加密 Interpark 密码、信用卡 CVV 等）
DATA_ENCRYPT_KEY=generate_a_32byte_key_here

# 数据库（默认 SQLite，生产建议 PostgreSQL）
# DATABASE_URL=postgresql://user:pass@localhost:5432/wvs

# CORS 允许的域名（逗号分隔，* 表示全部）
# CORS_ORIGINS=http://localhost:5000,https://yourdomain.com

# 端口
# PORT=5000
